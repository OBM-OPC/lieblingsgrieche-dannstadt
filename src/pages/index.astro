---
import Layout from '../layouts/Layout.astro';

// Menu data
const menuCategories = [
  {
    name: "Vorspeisen",
    items: [
      { name: "Tzatziki", description: "Frischer Joghurt-Dip mit Gurke und Knoblauch, dazu warmes Fladenbrot", price: 6.50 },
      { name: "Melitzanosalata", description: "Geröstete Auberginen mit Knoblauch, Olivenöl und Zitrone", price: 7.90 },
      { name: "Dolmades", description: "Gefüllte Weinblätter mit Reis, Kräutern und Zitronensauce", price: 8.50 },
      { name: "Saganaki", description: "Gebratener Schafskäse mit Zitrone und Fladenbrot", price: 9.90 }
    ]
  },
  {
    name: "Grill-Spezialitäten",
    items: [
      { name: "Gyros Teller", description: "Saftiges Gyros vom Spieß mit Pommes, Tzatziki und Salat", price: 14.90 },
      { name: "Souvlaki (2 Spieße)", description: "Zarte Schweinefilet-Spieße, mariniert nach griechischer Art", price: 13.50 },
      { name: "Bifteki (2 Stück)", description: "Saftige Frikadellen mit Fetafüllung, dazu Gemüse", price: 15.90 },
      { name: "Kalamari", description: "Knusprig frittierte Tintenfischringe mit Zitronensauce", price: 16.90 }
    ]
  },
  {
    name: "Hauptgerichte",
    items: [
      { name: "Moussaka", description: "Auberginen-Hackfleisch-Auflauf mit Béchamelsauce", price: 15.50 },
      { name: "Kleftiko", description: "Zartes Lamm im Backofen geschmort mit Kartoffeln und Kräutern", price: 22.90 },
      { name: "Souvlaki Platte", description: "Gemischte Grillplatte für zwei Personen", price: 38.90 },
      { name: "Gemista", description: "Gefüllte Paprika und Tomaten mit Reis und Kräutern", price: 13.90 }
    ]
  },
  {
    name: "Salate",
    items: [
      { name: "Griechischer Salat", description: "Tomaten, Gurken, Paprika, Oliven, Zwiebeln, Feta und Oregano", price: 11.90 },
      { name: "Salat mit Gyros", description: "Griechischer Salat mit saftigem Gyros vom Spieß", price: 15.90 },
      { name: "Salat mit Souvlaki", description: "Frischer Salat mit zwei gegrillten Schweinefilet-Spießen", price: 16.50 },
      { name: "Feta-Salat", description: "Blattsalat, Tomaten, Gurken, Zwiebeln und extra großer Fetakäse", price: 10.90 }
    ]
  }
];

// Gallery images from local folder
const galleryImages = [
  { id: "1", src: "/images/gallery-1.jpg", alt: "Griechischer Salat mit Feta" },
  { id: "2", src: "/images/gallery-2.jpg", alt: "Frische Souvlaki vom Grill" },
  { id: "3", src: "/images/gallery-3.jpg", alt: "Griechischer Salat mit frischem Gemüse" },
  { id: "4", src: "/images/gallery-4.jpg", alt: "Griechisches Fleischgericht vom Grill" },
  { id: "5", src: "/images/gallery-5.jpg", alt: "Mediterranes Essen mit Oliven und Brot" },
  { id: "6", src: "/images/gallery-6.jpg", alt: "Griechische Taverna bei Nacht" },
  { id: "7", src: "/images/gallery-7.jpg", alt: "Olive oil and Mediterranean herbs" },
  { id: "8", src: "/images/gallery-8.jpg", alt: "Griechische Desserts" }
];
---

<Layout>
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-40 bg-[#faf5eb]/95 backdrop-blur-sm border-b border-[#c8a951]/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex-shrink-0">
          <a href="#" class="text-xl font-semibold text-[#1a1a1a]" style="font-family: 'Playfair Display', serif;">
            Lieblingsgrieche
          </a>
        </div>
        
        <!-- Desktop Navigation -->
        <div class="hidden md:flex space-x-8">
          <a href="#speisekarte" class="nav-link text-sm font-medium text-[#1a1a1a] hover:text-[#97a926] transition-colors">Speisekarte</a>
          <a href="#galerie" class="nav-link text-sm font-medium text-[#1a1a1a] hover:text-[#97a926] transition-colors">Galerie</a>
          <a href="#kontakt" class="nav-link text-sm font-medium text-[#1a1a1a] hover:text-[#97a926] transition-colors">Kontakt</a>
        </div>
        
        <!-- Mobile Hamburger Button -->
        <button id="hamburger-btn" class="md:hidden p-2 -mr-2" aria-label="Menü öffnen">
          <div id="hamburger-icon" class="w-6 h-6 flex flex-col justify-center items-center relative">
            <span class="hamburger-line hamburger-line-1 block w-6 h-0.5 bg-[#1a1a1a] mb-1.5 origin-center"></span>
            <span class="hamburger-line hamburger-line-2 block w-6 h-0.5 bg-[#1a1a1a] mb-1.5"></span>
            <span class="hamburger-line hamburger-line-3 block w-6 h-0.5 bg-[#1a1a1a]"></span>
          </div>
        </button>
      </div>
    </div>
    
    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="mobile-menu fixed inset-0 top-16 z-50 bg-[#faf5eb] md:hidden">
      <div class="flex flex-col items-center justify-center h-full -mt-16 space-y-8">
        <a href="#speisekarte" class="mobile-nav-link text-2xl font-medium text-[#1a1a1a] hover:text-[#97a926] transition-colors">Speisekarte</a>
        <a href="#galerie" class="mobile-nav-link text-2xl font-medium text-[#1a1a1a] hover:text-[#97a926] transition-colors">Galerie</a>
        <a href="#kontakt" class="mobile-nav-link text-2xl font-medium text-[#1a1a1a] hover:text-[#97a926] transition-colors">Kontakt</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img 
        src="/images/hero.jpg" 
        alt="Griechisches Essen" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-[#1a1a1a]/70"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
      <p class="text-[#97a926] text-sm font-medium tracking-[0.3em] uppercase mb-4">
        Olive trifft Riesling
      </p>
      
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight"
        style="font-family: 'Playfair Display', serif;">
        Lieblingsgrieche
        <span class="block text-2xl sm:text-3xl md:text-4xl font-normal text-[#c8a951] mt-2">by Natasa</span>
      </h1>
      
      <p class="text-lg sm:text-xl text-[#f5f0e8]/90 mb-10 max-w-2xl mx-auto leading-relaxed">
        Authentische griechische Küche – frisch zubereitet mit Leidenschaft und traditionellen Rezepten aus dem Herzen Griechenlands.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#kontakt" class="btn-primary text-base">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          Reservieren
        </a>
        <a href="#speisekarte" class="btn-secondary text-base bg-white/10 border border-white/30 hover:bg-white/20">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
          Speisekarte
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- Speisekarte Section -->
  <section id="speisekarte" class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="text-[#97a926] text-sm font-medium tracking-[0.3em] uppercase mb-3">Unsere Spezialitäten</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-[#1a1a1a] mb-4" style="font-family: 'Playfair Display', serif;">
          Speisekarte
        </h2>
        <p class="text-[#8a8070] max-w-2xl mx-auto">
          Entdecken Sie unsere Auswahl an authentischen griechischen Gerichten, frisch zubereitet mit den besten Zutaten.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {menuCategories.map((category, index) => {
          const icons = ['🥗', '🔥', '🍽️', '🥬'];
          return (
            <div class={`menu-card fade-in fade-in-delay-${index + 1} bg-white rounded-2xl p-8 shadow-sm border border-[#c8a951]/10 border-l-4 border-l-[#97a926]`}>
              <h3 class="text-2xl font-semibold text-[#1a1a1a] mb-6 pb-4 border-b border-[#c8a951]/20 flex items-center" style="font-family: 'Playfair Display', serif;">
                <span class="menu-category-icon">{icons[index] || '🍴'}</span>
                {category.name}
              </h3>
              
              <div class="space-y-6">
                {category.items.map((item) => (
                  <div class="flex justify-between items-start group">
                    <div class="flex-1 pr-4">
                      <h4 class="font-medium text-[#1a1a1a] mb-1">{item.name}</h4>
                      <p class="text-sm text-[#8a8070]">{item.description}</p>
                    </div>
                    <span class="text-[#97a926] font-semibold text-lg whitespace-nowrap">
                      {item.price.toFixed(2)} €
                    </span>
                  </div>
                ))}
              </div>
            </div>
          );
        })}
      </div>

      <!-- Decorative Divider -->
      <div class="menu-divider max-w-md mx-auto mt-12">
        <span class="menu-divider-dot"></span>
      </div>

      <!-- Allergen-Hinweis -->
      <div class="mt-8 text-center">
        <p class="text-sm text-[#8a8070]">
          * Alle Preise in Euro. Änderungen vorbehalten. Bitte informieren Sie uns bei Allergien.
        </p>
      </div>
    </div>
  </section>

  <!-- Galerie Section -->
  <section id="galerie" class="py-20 bg-[#1a1a1a] px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="text-[#97a926] text-sm font-medium tracking-[0.3em] uppercase mb-3">Eindrücke</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-white mb-4" style="font-family: 'Playfair Display', serif;">
          Galerie
        </h2>
        <p class="text-[#8a8070] max-w-2xl mx-auto">
          Einblicke in unsere Gerichte und das gemütliche Ambiente unserer Taverna.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="gallery-grid">
        {galleryImages.map((image, index) => (
          <div class="gallery-item fade-in relative aspect-square overflow-hidden rounded-lg cursor-pointer group"
            data-index={index}
            style={`transition-delay: ${index * 50}ms`}
          >
            <img 
              src={image.src} 
              alt={image.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-[#97a926]/0 group-hover:bg-[#97a926]/20 transition-colors flex items-center justify-center">
              <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
              </svg>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Lightbox -->
    <div id="lightbox" class="fixed inset-0 z-50 hidden">
      <div class="absolute inset-0 bg-black/95 lightbox-overlay"></div>
      
      <button id="lightbox-close" class="absolute top-4 right-4 z-10 p-2 text-white hover:text-[#97a926] transition-colors">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      
      <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 p-2 text-white hover:text-[#97a926] transition-colors">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      
      <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 p-2 text-white hover:text-[#97a926] transition-colors">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
      
      <div class="absolute inset-0 flex items-center justify-center p-4">
        <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain"
/>
      </div>
    </div>
  </section>

  <!-- Kontakt Section -->
  <section id="kontakt" class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="text-[#97a926] text-sm font-medium tracking-[0.3em] uppercase mb-3">Kontaktieren Sie uns</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-[#1a1a1a] mb-4" style="font-family: 'Playfair Display', serif;">
          Kontakt & Anfahrt
        </h2>
        <p class="text-[#8a8070] max-w-2xl mx-auto">
          Reservieren Sie Ihren Tisch oder besuchen Sie uns spontan – wir freuen uns auf Ihren Besuch!
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div class="space-y-8">
          <!-- Öffnungszeiten -->
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-[#c8a951]/10">
            <h3 class="text-xl font-semibold text-[#1a1a1a] mb-6 flex items-center" style="font-family: 'Playfair Display', serif;">
              <svg class="w-6 h-6 text-[#97a926] mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Öffnungszeiten
            </h3>
            
            <div class="space-y-3">
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-[#8a8070]">Montag</span>
                <span class="text-[#1a1a1a] font-medium">Ruhetag</span>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-[#8a8070]">Dienstag – Samstag</span>
                <span class="text-[#1a1a1a] font-medium">17:30 – 24:00 Uhr</span>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-[#8a8070]">Sonn- und Feiertage</span>
                <span class="text-[#1a1a1a] font-medium">11:30 – 14:00 & 17:30 – 24:00</span>
              </div>
              <div class="mt-4 pt-3 border-t border-[#97a926]/20 bg-[#97a926]/5 rounded-lg p-3">
                <p class="text-sm text-[#8a8070]"><span class="font-medium text-[#1a1a1a]">Warme Küche</span> Di–Sa bis 22:00 Uhr</p>
                <p class="text-sm text-[#8a8070]"><span class="font-medium text-[#1a1a1a]">Warme Küche</span> So/Feiertage bis 20:30 Uhr</p>
              </div>
            </div>
          </div>

          <!-- Kontaktdaten -->
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-[#c8a951]/10">
            <h3 class="text-xl font-semibold text-[#1a1a1a] mb-6 flex items-center" style="font-family: 'Playfair Display', serif;">
              <svg class="w-6 h-6 text-[#97a926] mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Kontakt
            </h3>
            
            <div class="space-y-4">
              <div class="flex items-start">
                <svg class="w-5 h-5 text-[#97a926] mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <div>
                  <p class="font-medium text-[#1a1a1a]">Adresse</p>
                  <p class="text-[#8a8070]">Neckarstraße 2e<br/>67125 Dannstadt</p>
                </div>
              </div>
              
              <a href="tel:063219398866" class="flex items-center group">
                <svg class="w-5 h-5 text-[#97a926] mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <div>
                  <p class="font-medium text-[#1a1a1a] group-hover:text-[#97a926] transition-colors">Telefon</p>
                  <p class="text-[#8a8070]">06321 9398866</p>
                </div>
              </a>
              
              <a href="mailto:kontakt@restaurant-lieblingsgrieche2.de" class="flex items-center group">
                <svg class="w-5 h-5 text-[#97a926] mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <div>
                  <p class="font-medium text-[#1a1a1a] group-hover:text-[#97a926] transition-colors">E-Mail</p>
                  <p class="text-[#8a8070] text-sm break-all">kontakt@restaurant-lieblingsgrieche2.de</p>
                </div>
              </a>
            </div>
          </div>

          <!-- Service-Info -->
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-[#c8a951]/10">
            <h3 class="text-xl font-semibold text-[#1a1a1a] mb-6 flex items-center" style="font-family: 'Playfair Display', serif;">
              <svg class="w-6 h-6 text-[#97a926] mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Bei uns
            </h3>
            <div class="flex flex-wrap gap-3">
              <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#97a926]/10 text-[#97a926] rounded-full text-sm font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                Karten & Bar
              </span>
              <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#97a926]/10 text-[#97a926] rounded-full text-sm font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.964 5.964 0 01-.015.015m0 0L6.5 18m1.611-1.596a5.964 5.964 0 01-.015-.015m0 0L6.5 14m7.611 2.404a5.964 5.964 0 01-.015.015m0 0L12.5 18m1.611-1.596a5.964 5.964 0 01-.015-.015m0 0L12.5 14M3 12h18"/></svg>
                WLAN
              </span>
              <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#97a926]/10 text-[#97a926] rounded-full text-sm font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
                Parkplätze
              </span>
            </div>
          </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-[#c8a951]/10">
          <h3 class="text-xl font-semibold text-[#1a1a1a] mb-6 flex items-center" style="font-family: 'Playfair Display', serif;">
            <svg class="w-6 h-6 text-[#97a926] mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
