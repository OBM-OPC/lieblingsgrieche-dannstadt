---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Lieblingsgrieche by Natasa - Griechisches Restaurant in Dannstadt",
  description = "Authentische griechische Küche in Dannstadt. Besuchen Sie uns für Gyros, Souvlaki, Meze und mehr. Reservieren Sie jetzt Ihren Tisch!"
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "name": "Lieblingsgrieche by Natasa",
  "image": "",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Neckarstraße 2e",
    "addressLocality": "Dannstadt",
    "postalCode": "67125",
    "addressCountry": "DE"
  },
  "telephone": "+4963219398866",
  "email": "kontakt@restaurant-lieblingsgrieche2.de",
  "url": "https://restaurant-lieblingsgrieche2.de",
  "servesCuisine": "Greek",
  "priceRange": "€€",
  "openingHours": [
    "Tu-Sa 16:00-22:00",
    "Su 12:00-23:00"
  ]
};
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
