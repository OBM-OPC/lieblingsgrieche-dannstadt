---
export interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Lieblingsgrieche by Natasa - Griechisches Restaurant in Dannstadt",
  description = "Authentische griechische Küche in Dannstadt. Besuchen Sie uns für Gyros, Souvlaki, Meze und mehr. Reservieren Sie jetzt Ihren Tisch!"
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "name": "Lieblingsgrieche by Natasa",
  "image": "",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Neckarstraße 2e",
    "addressLocality": "Dannstadt",
    "postalCode": "67125",
    "addressCountry": "DE"
  },
  "telephone": "+4963219398866",
  "email": "kontakt@restaurant-lieblingsgrieche2.de",
  "url": "https://restaurant-lieblingsgrieche2.de",
  "servesCuisine": "Greek",
  "priceRange": "€€",
  "openingHours": [
    "Tu-Sa 16:00-22:00",
    "Su 12:00-23:00"
  ]
};
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <style is:global>
      /* Tailwind CSS v4 */
      @import "tailwindcss";
      
      /* Custom CSS Variables */
      :root {
        --color-olive: #97a926;
        --color-charcoal: #1a1a1a;
        --color-warm-cream: #faf5eb;
        --color-gold: #c8a951;
        --color-off-white: #f5f0e8;
        --color-warm-gray: #8a8070;
      }
      
      /* Base Styles */
      html {
        scroll-behavior: smooth;
      }
      
      body {
        font-family: 'Inter', sans-serif;
        background-color: var(--color-warm-cream);
        color: var(--color-charcoal);
      }
      
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Playfair Display', serif;
      }
      
      /* Animation Classes */
      .fade-in {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
      }
      
      .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }
      
      /* Form Styles */
      input, textarea, select {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid #d1d5db;
        border-radius: 0.5rem;
        outline: none;
        transition: all 0.2s;
      }
      
      input:focus, textarea:focus, select:focus {
        border-color: transparent;
        box-shadow: 0 0 0 2px var(--color-olive);
      }
      
      /* Button Styles */
      .btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 2rem;
        background-color: #97a926;
        color: white;
        font-weight: 500;
        border-radius: 0.5rem;
        transition: background-color 0.2s;
      }
      
      .btn-primary:hover {
        background-color: #7a8a1f;
      }
      
      .btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 2rem;
        background-color: #1a1a1a;
        color: white;
        font-weight: 500;
        border-radius: 0.5rem;
        transition: background-color 0.2s;
      }
      
      .btn-secondary:hover {
        background-color: #333;
      }
      
      /* Sticky Bottom Bar */
      .sticky-bottom-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 50;
        background: white;
        border-top: 1px solid #e5e5e5;
      }
      
      @media (min-width: 768px) {
        .sticky-bottom-bar {
          display: none;
        }
      }
      
      /* Lightbox */
      .lightbox-overlay {
        backdrop-filter: blur(8px);
      }
    </style>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
